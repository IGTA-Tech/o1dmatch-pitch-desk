# =============================================================================
# O1DMatch Pitch Desk - environment variables
# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local`.
# =============================================================================

# --- Neon Postgres -----------------------------------------------------------
# Get from: https://console.neon.tech > your project > Connection Details
# Use the "Pooled connection" string. SSL required.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Clerk (auth) ------------------------------------------------------------
# Get from: https://dashboard.clerk.com > your app > API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# --- OpenRouter (AI gateway) -------------------------------------------------
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-..."

# Optional: app identification headers (shown on OpenRouter dashboard)
OPENROUTER_APP_URL="https://o1dmatch-pitch-desk.vercel.app"
OPENROUTER_APP_NAME="O1DMatch Pitch Desk"

# Model routing - override the defaults if needed.
# Primary: GLM-5.1 (IFBench leader, MIT license, ~$0.90/M blended).
AI_MODEL_PRIMARY="z-ai/glm-4.6"
# Bulk lane: DeepSeek V3.2 (~$0.10/M blended).
AI_MODEL_BULK="deepseek/deepseek-chat"
# Fallback: OpenAI gpt-4.1-mini (json_schema strict mode).
AI_MODEL_FALLBACK="openai/gpt-4.1-mini"

# --- Google Sheets mirror ----------------------------------------------------
# Three ways to pass credentials. Pick ONE (preference top to bottom).
#
# PATH A (RECOMMENDED for cloud - bulletproof against paste corruption):
# Base64-encoded private key. Alphanumeric only - no paste UI can mangle it.
# Generate with: node scripts/show-credentials.mjs <path/to/key.json>
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY_B64=""
#
# PATH B (escape-encoded - works if your env-var UI handles backslashes):
# Same email var as Path A; key with literal \n sequences on one line.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=""
#
# PATH C (legacy - whole JSON in one var). Has auto-repair for real-newline
# corruption but is the most fragile. Only used if A and B are empty.
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@...iam.gserviceaccount.com",...}'

# The Google Sheet ID (from the URL: docs.google.com/spreadsheets/d/THIS_PART/edit)
GOOGLE_SHEET_ID=""

# --- Feature flags -----------------------------------------------------------
# When true, all AI calls return canned mock data (no API spend, no network).
# Set to "false" once OPENROUTER_API_KEY is live and you've tested the UI.
BETA_MOCK_MODE="true"
